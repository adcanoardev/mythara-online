// apps/server/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Users & Auth ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  game           Game?
  trainerProfile TrainerProfile?
  combatTokens   CombatToken?
  inventory      Inventory[]
  structures     Structure[]
  creatures      CreatureInstance[]
  battleLogs     BattleLog[]
  mailMessages   MailMessage[]
  trainerInventory TrainerInventory[]
  equipmentInstances EquipmentInstance[]
  arenaDefense   ArenaDefense?
  arenaMatches   ArenaMatch[]       @relation("AttackerMatches")
  arenaDefenses  ArenaMatch[]       @relation("DefenderMatches")
}

model Game {
  id        String   @id @default(cuid())
  seed      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  starterId Int
}

// ─── Trainer Profile ──────────────────────────────────────────

model TrainerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  level    Int   @default(1)
  xp       Int   @default(0)
  prestige Int   @default(0)
  coins    Int   @default(0)
  medals   Int[] @default([])

  avatar             String?
  gender             String?
  onboardingComplete Boolean @default(false)

  // Currency
  gold               Int      @default(0)
  diamonds           Int      @default(0)

  // Cosmetics — server-validated only
  avatarFrame        String?
  unlockedFrames     String[] @default([])

  // Sanctums progression
  binderLevel        Int      @default(1)
  sanctumClears      Int[]    @default([])

  // Nexus — Essences
  essences           Int      @default(0)
  corruptedEssences  Int      @default(0)
  mythicEssences     Int      @default(0)

  // Nexus — Pity counters (purple)
  pityRare           Int      @default(0)
  pityEpic           Int      @default(0)
  pityElite          Int      @default(0)
  pityLegendary      Int      @default(0)

  // Nexus — Pity counters (gold — separate from purple)
  pityEliteGold      Int      @default(0)
  pityLegendaryGold  Int      @default(0)

  // Gold Essences
  goldEssences       Int      @default(0)

  // Activity
  lastSeen  DateTime @default(now())

  // Guild
  guildId   String?
  guildRole String?
  guild     Guild?   @relation(fields: [guildId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Nexus — Weekly Banner ────────────────────────────────────

model NexusBanner {
  id             Int      @id @default(autoincrement())
  startsAt       DateTime
  endsAt         DateTime
  boostedMythIds String[]
  isActive       Boolean  @default(true)

  createdAt DateTime @default(now())
}

// ─── Guild ────────────────────────────────────────────────────

model Guild {
  id          String   @id @default(cuid())
  name        String   @unique
  tag         String   @unique
  banner      String   @default("#7b2fff")
  level       Int      @default(1)
  description String   @default("")
  leaderId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  xp       Int @default(0)
  members  TrainerProfile[]
  quests   GuildQuest[]
  messages GuildMessage[]
}

enum QuestType {
  WIN_BATTLES
  OPEN_ESSENCES
  COLLECT_MINE
  COMPLETE_SANCTUM
  WIN_PVP
}

model GuildQuest {
  id          String    @id @default(cuid())
  guildId     String
  guild       Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  type        QuestType
  description String
  target      Int
  progress    Int       @default(0)
  date        String
  reward50    String    @default("TOKENS")
  reward100   String    @default("TOKENS_GEMS")
  claimed50   String[]  @default([])
  claimed100  String[]  @default([])

  contributions GuildQuestContribution[]

  createdAt DateTime @default(now())
}

model GuildQuestContribution {
  id        String     @id @default(cuid())
  questId   String
  quest     GuildQuest @relation(fields: [questId], references: [id], onDelete: Cascade)
  userId    String
  amount    Int
  createdAt DateTime   @default(now())
}

model GuildMessage {
  id        String   @id @default(cuid())
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  userId    String
  username  String
  guildTag  String
  content   String
  createdAt DateTime @default(now())
}

model GlobalMessage {
  id        String   @id @default(cuid())
  userId    String
  username  String
  guildTag  String   @default("")
  content   String
  createdAt DateTime @default(now())
}

// ─── Combat Tokens ────────────────────────────────────────────

model CombatToken {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  npcTokens Int @default(10)
  pvpTokens Int @default(5)

  lastNpcRecharge DateTime @default(now())
  lastPvpRecharge DateTime @default(now())

  updatedAt DateTime @updatedAt
}

// ─── Outpost Structures ───────────────────────────────────────

model Structure {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type          StructureType
  level         Int           @default(1)
  lastCollected DateTime      @default(now())
  structureXp   Int           @default(0)

  dailyDiamonds    Int      @default(0)
  lastDiamondReset DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type])
}

enum StructureType {
  MINE
  FORGE
  LAB
  NURSERY
}

// ─── Legacy Inventory (enum-based) ───────────────────────────

model Inventory {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  item     ItemType
  quantity Int      @default(0)

  @@unique([userId, item])
}

enum ItemType {
  SHARD
  CRYSTAL
  RUNE
  ELIXIR
  MEGA_ELIXIR
  GRAND_ELIXIR
  SPARK
  GRAND_SPARK
  EMBER_SHARD
  TIDE_SHARD
  VOLT_SHARD
  GROVE_SHARD
  FROST_SHARD
  BOND_CRYSTAL
  ASTRAL_SCALE
  IRON_COAT
  SOVEREIGN_STONE
  CIPHER_CORE
  BLUE_DIAMOND
  ROCK_FRAGMENT
  ARCANE_GEAR
  FLAME_CORE
}

// ─── Myth Instances (existing battle system) ─────────────────

model CreatureInstance {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  speciesId  String
  nickname   String?
  level      Int     @default(1)
  xp         Int     @default(0)
  hp         Int
  maxHp      Int
  attack     Int
  defense    Int
  speed      Int
  accuracy   Int @default(100)
  critChance Int @default(15)
  critDamage Int @default(150)

  isInParty Boolean @default(false)
  slot      Int?
  inNursery Boolean @default(false)

  obtainedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Battle Logs ──────────────────────────────────────────────

model BattleLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type              BattleType
  result            BattleResult
  xpGained          Int          @default(0)
  coinsGained       Int          @default(0)

  playerSpeciesId   String
  playerLevel       Int
  enemySpeciesId    String
  enemyLevel        Int
  capturedSpeciesId String?

  createdAt DateTime @default(now())
}

enum BattleType {
  NPC
  PVP
}

enum BattleResult {
  WIN
  LOSE
  DRAW
}

// ─── MailBox ──────────────────────────────────────────────────

model MailMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  type        MailType @default(SYSTEM)
  title       String
  body        String
  isRead      Boolean  @default(false)
  claimedAt   DateTime?
  expiresAt   DateTime
  attachments Json?    // { gold, diamonds, essences, goldEssences, items: [{itemSlug, qty}] }
  actionData  Json?    // { type: "GUILD_REQUEST", guildId, ... }

  createdAt DateTime @default(now())
}

enum MailType {
  SYSTEM
  GUILD
  PROMO
}

// ─── Items (new system) ───────────────────────────────────────

model Item {
  id          Int    @id @default(autoincrement())
  slug        String @unique
  name        String
  description String
  category    String // EQUIPMENT | CONSUMABLE | ESSENCE | MATERIAL | KEY | BOOSTER
  rarity      String // COMMON | RARE | EPIC | LEGENDARY
  iconUrl     String
  isActive    Boolean @default(true)

  trainerInventory TrainerInventory[]
  equipmentInstances EquipmentInstance[]

  createdAt DateTime @default(now())
}

model TrainerInventory {
  id        Int    @id @default(autoincrement())
  userId    String
  user      User   @relation(fields: [userId], references: [id])
  itemId    Int
  item      Item   @relation(fields: [itemId], references: [id])
  quantity  Int    @default(1)

  @@unique([userId, itemId])
}

model EquipmentInstance {
  id        Int    @id @default(autoincrement())
  userId    String
  user      User   @relation(fields: [userId], references: [id])
  itemId    Int
  item      Item   @relation(fields: [itemId], references: [id])

  level     Int    @default(1)
  mainStat  String
  mainValue Float
  subStat1  String? @map("sub_stat1")
  subValue1 Float?  @map("sub_value1")
  subStat2  String? @map("sub_stat2")
  subValue2 Float?  @map("sub_value2")
  subStat3  String? @map("sub_stat3")
  subValue3 Float?  @map("sub_value3")
  equippedOn String? // creatureInstance id

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Arena PvP ────────────────────────────────────────────────

model ArenaDefense {
  id        Int    @id @default(autoincrement())
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id])

  // Defense team — speciesIds from CreatureInstance
  myth1Id   String
  myth2Id   String
  myth3Id   String

  // AI strategy per slot: AGGRESSIVE | BALANCED | DEFENSIVE
  strategy1 String @default("BALANCED")
  strategy2 String @default("BALANCED")
  strategy3 String @default("BALANCED")

  // Trophy count (1000 = Silver tier start)
  trophies  Int    @default(1000)

  updatedAt DateTime @updatedAt
}

model ArenaMatch {
  id         Int      @id @default(autoincrement())

  attackerId String
  attacker   User     @relation("AttackerMatches", fields: [attackerId], references: [id])

  defenderId String
  defender   User     @relation("DefenderMatches", fields: [defenderId], references: [id])

  winnerId   String   // userId of winner
  trophyDelta Int     // trophies gained/lost (positive = attacker won)
  replayData  Json    // full battle state for replay

  createdAt DateTime @default(now())
}
